# API origin only (no trailing slash). Client calls: ${VITE_API_BASE_URL}/api/v1/...
VITE_API_BASE_URL=http://localhost:8080

# JSON responses: { success: true, data } | { success: false, error: { code, message, kind } }
# Auth: POST /api/v1/auth/login body { "login": "email|phone", "password" }
# Tokens: access_token, refresh_token; header: Authorization: Bearer <access_token>
# GET /api/v1/auth/me — user; roles: super_admin | admin | teacher | student
# POST /api/v1/auth/refresh body { "refresh_token": "..." }

# Optional: enable React Query devtools in production builds (default: off in prod)
# VITE_ENABLE_QUERY_DEVTOOLS=true

# Rich sample data for the admin dashboard (no live /dashboard/summary required)
# VITE_DASHBOARD_DEMO=true

# Students module: localStorage-backed mock API (omit for real REST integration)
# VITE_STUDENTS_DEMO=true

# Teachers module: localStorage-backed mock API (omit for real REST integration)
# VITE_TEACHERS_DEMO=true

# Subjects catalog (admin CRUD + teacher pickers when demo is on)
# VITE_SUBJECTS_DEMO=true

# Rooms inventory (capacity, building, notes)
# VITE_ROOMS_DEMO=true

# Groups (cohorts, fees, teacher/subject/room assignments, student roster)
# VITE_GROUPS_DEMO=true

# Weekly schedule (lesson slots)
# VITE_SCHEDULE_DEMO=true

# Lesson attendance & grades (per session date)
# VITE_ATTENDANCE_DEMO=true

# AI admin insights page: sample snapshot without GET /ai/analytics/snapshot
# VITE_AI_ANALYTICS_DEMO=true
